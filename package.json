{
  "name": "@whoj/eslint-config-monorepo",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Jonson B.",
    "email": "www.jbc.bd@gmail.com",
    "url": "https://github.com/who-jonson"
  },
  "packageManager": "pnpm@8.6.3",
  "scripts": {
    "lint": "eslint \"{**/*,*}.{js,ts,tsx,vue}\" --fix",
    "prepare": "pnpm -r run stub",
    "release": "bumpp packages/*/package.json --commit --push --tag && pnpm -r publish --access public"
  },
  "devDependencies": {
    "@whoj/eslint-config": "workspace:*",
    "bumpp": "^9.1.1",
    "eslint": "^8.43.0",
    "eslint-plugin-whoj": "workspace:*",
    "typescript": "^5.0.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "latest"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "eslint",
        "typescript"
      ]
    }
  }
}
